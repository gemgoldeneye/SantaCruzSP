# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (hoisted at root + per-package)
node_modules/
.pnp
.pnp.*
.pnpm-store/

# build output
dist/
dev-dist/
build/
out/
.next/
*.tsbuildinfo

# Serwist PWA service worker (emitted by `next build`)
apps/web/public/sw.js
apps/web/public/sw.js.map
apps/web/public/swe-worker-*.js

# testing
coverage/

# drizzle (generated migration journal is committed; transient meta is not)
**/drizzle/meta/_journal.json.bak

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
next-env.d.ts

# legacy Next.js app generated Prisma client
legacy/web/src/generated/prisma
