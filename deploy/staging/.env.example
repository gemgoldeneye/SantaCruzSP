# SantaCruzSP STAGING — copy to deploy/staging/.env on the VPS (gitignored).
# In the pipeline this file is GENERATED by remote-deploy.sh from the Jenkins
# credentials/params — this is just a REFERENCE for what those hold. Put the real
# values in Jenkins (Secret text), not here. Use a SEPARATE DB from prod.
#
# Managed Postgres + Redis. SP_DATABASE_URL = the app role (RLS-scoped, used by
# the running api); SP_OWNER_DATABASE_URL = the owner role (migrations + seed,
# bypasses RLS). Provision an isolated staging DB (e.g. sp_stacruz_staging).
SP_DATABASE_URL=postgres://sp_app:<generated-pw>@<db-host>:5432/sp_stacruz_staging?sslmode=require
SP_OWNER_DATABASE_URL=postgres://sp_owner:<generated-pw>@<db-host>:5432/sp_stacruz_staging?sslmode=require
# Redis for sessions/sync. Use a dedicated DB index isolated from prod + the OVR apps.
SP_REDIS_URL=rediss://default:<generated-pw>@<redis-host>:6379
SP_SESSION_SECRET=replace-with-long-random-string-staging
# CORS: the public web origin the api will accept (the web is the only public host).
SP_CORS_ORIGINS=https://sp-stacruz-staging.glstest.site
# Optional — payment gateway webhook HMAC secret (blank = disabled).
SP_PAYMENT_WEBHOOK_SECRET=

API_REPLICAS=1
WEB_REPLICAS=1
