{
  "name": "santacruz-sp-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Santa Cruz Sanggunian governance platform — a per-LGU deployment consuming the @gelabs/sp SDK (Next web + Fastify api + config/santacruz); offline-first, federated.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev:api": "pnpm --filter @sp/api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "smoke": "pnpm --filter @sp/api smoke",
    "db:up": "docker compose -f deploy/dev/compose.yml up -d",
    "db:down": "docker compose -f deploy/dev/compose.yml down",
    "db:reset": "docker compose -f deploy/dev/compose.yml down -v",
    "db:logs": "docker compose -f deploy/dev/compose.yml logs -f",
    "db:migrate": "pnpm --filter @sp/api db:migrate",
    "db:seed": "pnpm --filter @sp/api db:seed"
  }
}
