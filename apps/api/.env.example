# @sp/api — copy to .env for local dev. Defaults match deploy/dev/compose.yml.

# Runtime connects as the NON-OWNER role so RLS applies.
DATABASE_URL=postgres://zsp_app:zsp_app_dev@localhost:5500/sp
# Migrations + seed run as the OWNER role (bypasses RLS).
OWNER_DATABASE_URL=postgres://zsp:zsp_dev@localhost:5500/sp
REDIS_URL=redis://localhost:6400

PORT=8787
SESSION_SECRET=dev-only-secret-do-not-use-in-prod

# Federation topology (Phase 7). NODE_ROLE: cloud (province hub) | onprem (Santa Cruz node).
NODE_ROLE=cloud
NODE_ID=cloud-hub
PROVINCE_TENANT=zambales-province
DEFAULT_TENANT=santacruz-zambales

# Seed mode: 'demo' (default — full demo data + logins) | 'bootstrap' (ONE env
# superadmin + reference data, NO demo logins/documents/sessions). Bootstrap
# REQUIRES both vars below; log in with this password then change it via the
# topbar key button. This file is gitignored — keep real secrets out of git.
SEED_MODE=demo
BOOTSTRAP_ADMIN_EMAIL=admin@santacruz.gov.ph
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong

# LGU-owned payment gateway webhook (HMAC).
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret

# Vite dev origins allowed to call the API with cookies.
CORS_ORIGINS=http://localhost:5201,http://localhost:5175
